---
import themes from '../data/themes.json';
const { variant = 'footer' } = Astro.props;

const selectClass =
  variant === 'drawer'
    ? 'w-full appearance-none font-mono text-xs tracking-[1.5px] text-white bg-white/10 border border-white/20 rounded-[10px] py-3 pl-[14px] pr-[30px] cursor-pointer'
    : 'appearance-none font-mono text-[11px] tracking-[1px] text-white bg-white/10 border border-white/20 rounded-full py-2 pl-[13px] pr-[26px] cursor-pointer';
const wrapClass = variant === 'drawer' ? 'flex items-center gap-[9px] mt-5 mb-[14px] w-full' : 'flex items-center gap-[9px]';
---

<div class={wrapClass}>
  <span class="font-mono text-[11px] tracking-[2px] text-white/50">THEME</span>
  <div class={variant === 'drawer' ? 'relative flex-1' : 'relative'}>
    <select data-theme-select aria-label="Color theme" class={selectClass}>
      {themes.options.map((o) => <option value={o.value} style="color:#1A2340;">{o.label}</option>)}
    </select>
    <span class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-white text-[9px]">&#9662;</span>
  </div>
</div>
