---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
const c = site.contact;
const fieldClass = 'font-sans text-[14.5px] text-ink rounded-[11px] px-[14px] py-[13px]';
const fieldStyle = 'background:#FBFAF7;border:1.5px solid var(--hp-border);';
---

<Base
  title="Contact — H.P. Industries"
  description="Contact H.P. Industries for retail or bulk pressure-cooker orders. Pan-India shipping, multiple payment modes, WhatsApp enquiries."
  active="contact"
>
  <!-- HERO -->
  <header class="relative overflow-hidden" style="padding:128px clamp(20px,5vw,64px) 50px;background:linear-gradient(160deg,var(--hp-bg) 0%,var(--hp-warm) 100%);">
    <div class="absolute pointer-events-none" style="top:-20%;right:-6%;width:50vw;height:50vw;max-width:600px;max-height:600px;background:radial-gradient(circle,color-mix(in srgb,var(--hp-copper) 14%,transparent),transparent 62%);"></div>
    <div class="relative mx-auto" style="max-width:1180px;">
      <div data-anim class="font-mono text-xs tracking-[2px] text-muted mb-4" style="--d:.1s"><a href="/index.html" class="text-muted no-underline">HOME</a> &nbsp;/&nbsp; <span class="text-accent-text">CONTACT</span></div>
      <h1 data-anim class="m-0 font-display font-extrabold text-ink" style="--d:.22s;font-size:clamp(38px,5.4vw,68px);line-height:1.04;letter-spacing:-1px;">Let's Talk Business</h1>
      <p data-anim class="text-body leading-[1.7] max-w-[52ch] mt-[22px]" style="--d:.34s;font-size:clamp(16px,1.4vw,18.5px);">Whether you're a retail buyer or a distributor planning a bulk order, send us your requirement and we'll respond with pricing and dispatch timelines.</p>
    </div>
  </header>

  <!-- SPLIT -->
  <section style="padding:clamp(40px,6vw,72px) clamp(20px,5vw,64px) clamp(56px,7vw,90px);">
    <div class="mx-auto grid items-start max-[900px]:grid-cols-1" style="max-width:1180px;grid-template-columns:1.1fr .9fr;gap:clamp(28px,4vw,56px);">

      <!-- FORM (native mailto submission — no JS) -->
      <form
        data-anim
        action={`mailto:${c.email}`}
        method="post"
        enctype="text/plain"
        class="bg-surface rounded-[22px]"
        style="--d:.15s;border:1px solid var(--hp-border);padding:clamp(26px,3vw,40px);box-shadow:0 30px 60px -40px rgba(31,36,51,.4);"
      >
        <h2 class="m-0 mb-[6px] font-display font-bold text-[26px] text-ink">Send an Enquiry</h2>
        <p class="m-0 mb-6 text-muted text-sm">Submitting opens your email app with the details prefilled. We typically reply within one business day.</p>
        <div class="grid gap-4 max-[520px]:grid-cols-1" style="grid-template-columns:1fr 1fr;">
          <label class="flex flex-col gap-[7px]"><span class="font-mono text-[11px] tracking-[1px] text-muted">NAME *</span><input name="Name" required type="text" placeholder="Your name" class={fieldClass} style={fieldStyle} /></label>
          <label class="flex flex-col gap-[7px]"><span class="font-mono text-[11px] tracking-[1px] text-muted">COMPANY</span><input name="Company" type="text" placeholder="Company name" class={fieldClass} style={fieldStyle} /></label>
          <label class="flex flex-col gap-[7px]"><span class="font-mono text-[11px] tracking-[1px] text-muted">PHONE *</span><input name="Phone" required type="tel" placeholder="+91-8285482863" class={fieldClass} style={fieldStyle} /></label>
          <label class="flex flex-col gap-[7px]"><span class="font-mono text-[11px] tracking-[1px] text-muted">EMAIL</span><input name="Email" type="email" placeholder="you@email.com" class={fieldClass} style={fieldStyle} /></label>
          <label class="flex flex-col gap-[7px]" style="grid-column:1 / -1;"><span class="font-mono text-[11px] tracking-[1px] text-muted">PRODUCT INTEREST</span>
            <div class="relative">
              <select name="Product Interest" class={`w-full appearance-none cursor-pointer ${fieldClass}`} style={fieldStyle}>
                <option>Standard Series</option><option>Matka Style</option><option>Contura Style</option><option>Bulk Enquiry</option>
              </select>
              <span class="absolute right-[15px] top-1/2 -translate-y-1/2 pointer-events-none text-accent-text text-[11px]">&#9662;</span>
            </div>
          </label>
          <label class="flex flex-col gap-[7px]" style="grid-column:1 / -1;"><span class="font-mono text-[11px] tracking-[1px] text-muted">MESSAGE</span><textarea name="Message" rows="4" placeholder="Sizes, quantities, timelines…" class={`resize-y ${fieldClass}`} style={fieldStyle}></textarea></label>
        </div>
        <button type="submit" class="hp-btn-primary mt-[22px] w-full justify-center text-base p-4 rounded-xl">Send Enquiry <span style="font-family:var(--font-mono)">&rarr;</span></button>
      </form>

      <!-- INFO -->
      <div data-anim class="flex flex-col gap-[18px]" style="--d:.28s">
        <div class="rounded-[18px] p-[26px]" style="background:var(--hp-warm);border:1px solid var(--hp-border);">
          <div class="flex flex-col gap-[18px]">
            <div class="flex gap-[14px] items-start"><span class="w-10 h-10 rounded-[10px] bg-surface flex items-center justify-center flex-none" style="border:1px solid var(--hp-border);"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--hp-accenttext)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg></span><div><div class="font-mono text-[11px] tracking-[1px] text-muted mb-1">ADDRESS</div><div class="text-[14.5px] text-ink leading-[1.5]">{c.company}, {c.address}</div></div></div>
            <div class="flex gap-[14px] items-start"><span class="w-10 h-10 rounded-[10px] bg-surface flex items-center justify-center flex-none" style="border:1px solid var(--hp-border);"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--hp-accenttext)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"/></svg></span><div><div class="font-mono text-[11px] tracking-[1px] text-muted mb-1">PHONE</div><div class="text-[14.5px] text-ink">{c.phone}</div></div></div>
            <div class="flex gap-[14px] items-start"><span class="w-10 h-10 rounded-[10px] bg-surface flex items-center justify-center flex-none" style="border:1px solid var(--hp-border);"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--hp-accenttext)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></span><div><div class="font-mono text-[11px] tracking-[1px] text-muted mb-1">EMAIL</div><div class="text-[14.5px] text-ink">{c.email}</div></div></div>
            <div class="flex gap-[14px] items-start"><span class="w-10 h-10 rounded-[10px] bg-surface flex items-center justify-center flex-none" style="border:1px solid var(--hp-border);"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--hp-accenttext)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/></svg></span><div><div class="font-mono text-[11px] tracking-[1px] text-muted mb-1">GST NUMBER</div><div class="font-mono text-[13.5px] text-ink">{c.gst}</div></div></div>
          </div>
        </div>
        <div class="relative rounded-[18px] overflow-hidden flex items-center justify-center" style="border:1px solid var(--hp-border);aspect-ratio:16/10;background:linear-gradient(135deg,#EEEAE0,#F6F1E8);">
          <div class="absolute inset-0" style="background-image:linear-gradient(color-mix(in srgb,var(--hp-copper) 8%,transparent) 1px,transparent 1px),linear-gradient(90deg,color-mix(in srgb,var(--hp-copper) 8%,transparent) 1px,transparent 1px);background-size:34px 34px;"></div>
          <div class="relative text-center"><svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="var(--hp-accenttext)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:8px;"><path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg><div class="font-mono text-[11px] tracking-[1px] text-muted">MAP EMBED — UTTAR PRADESH</div></div>
        </div>
        <a href={`https://wa.me/${c.whatsapp}`} target="_blank" rel="noopener" class="flex items-center justify-center gap-3 text-white no-underline font-semibold text-base p-4 rounded-[14px]" style="background:#1FA855;box-shadow:0 12px 28px -12px rgba(31,168,85,.6);">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="#fff"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2Zm0 18.15c-1.5 0-2.97-.4-4.25-1.16l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.37c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.42 5.83c0 4.54-3.71 8.24-8.25 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.8-.78.97-.14.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.39.11-.51.11-.11.25-.29.37-.43.13-.15.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
          Chat with us on WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- PAYMENT + SHIPPING -->
  <section style="background:var(--hp-warm);padding:clamp(50px,6vw,78px) clamp(20px,5vw,64px);">
    <div class="mx-auto grid items-center max-[820px]:grid-cols-1" style="max-width:1180px;grid-template-columns:1.2fr 1fr;gap:40px;">
      <div>
        <div class="hp-eyebrow mb-4">PAYMENT MODES</div>
        <div class="flex flex-wrap gap-3">
          {['Cash', 'Cheque', 'DD', 'Online'].map((m) => (
            <span class="flex items-center gap-[9px] bg-surface rounded-xl px-[18px] py-3 text-sm font-semibold text-ink" style="border:1px solid var(--hp-border);"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--hp-accenttext)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/></svg>{m}</span>
          ))}
        </div>
      </div>
      <div class="rounded-[18px] p-7 text-white" style="background:#19202E;">
        <div class="flex items-center gap-3 mb-3"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#D79A5B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h11v9H2zM13 10h4l3 3v3h-7z"/><circle cx="6" cy="18" r="1.8"/><circle cx="17" cy="18" r="1.8"/></svg><span class="font-mono text-[11px] tracking-[2px]" style="color:#D79A5B;">SHIPPING</span></div>
        <p class="m-0 text-base leading-[1.6] text-white/85">We ship <strong class="text-white">Pan-India by Road</strong>. Contact us for bulk dispatch timelines and freight estimates.</p>
      </div>
    </div>
  </section>
</Base>
