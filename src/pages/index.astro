---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import site from '../data/site.json';
import data from '../data/products.json';

const featured = data.products.filter((p) => p.featured);

const SAFETY_ICONS = [
  '<circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3.2"/>',
  '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/>',
  '<circle cx="12" cy="12" r="9"/><path d="M16 9l-5 6-3-3"/>',
  '<path d="M12 3l7 3v6c0 4.2-2.8 7.5-7 9-4.2-1.5-7-4.8-7-9V6z"/>',
];

// Visual build order for the anatomy callouts (alternating left/right).
const leftSeq = [0, 2, 4];
const rightSeq = [1, 3, 5];
const leftCallouts = [
  { name: 'HP TriLock™ Lid', sub: 'Triple-point locking' },
  { name: 'HP SafeSeal™ Gasket', sub: 'Precision-fit rubber seal' },
  { name: 'HP ComfortGrip™ Handles', sub: 'Stay-cool side grips' },
];
const rightCallouts = [
  { name: 'HP SafeValve™', sub: 'Precision pressure release' },
  { name: 'HP DuraCook™ Body', sub: 'ISI-standard aluminium' },
  { name: 'HP InducoBase™ Plate', sub: 'Induction-ready base' },
];
---

<Base
  title="H.P. Industries — Premium Aluminium Pressure Cookers"
  description="H.P. Industries manufactures premium aluminium pressure cookers from Uttar Pradesh, India — engineered for everyday kitchens and trusted by wholesale partners nationwide."
  active="home"
  navTransparent={true}
>
  <!-- HERO -->
  <header id="top" class="relative flex items-center overflow-hidden" style="min-height:92vh;background:linear-gradient(160deg,var(--hp-bg) 0%,var(--hp-warm) 100%);">
    <div class="absolute pointer-events-none" style="top:-10%;right:-6%;width:60vw;height:60vw;max-width:760px;max-height:760px;background:radial-gradient(circle,color-mix(in srgb,var(--hp-copper) 16%,transparent),transparent 62%);"></div>
    <div class="relative z-[3] w-full mx-auto grid items-center gap-12 max-[900px]:grid-cols-1" style="max-width:1180px;padding:110px clamp(20px,5vw,64px) 70px;grid-template-columns:1.05fr .95fr;">
      <div>
        <div data-anim class="font-mono text-[13px] tracking-[4px] text-accent-text mb-6" style="--d:.15s">H·P INDUSTRIES &nbsp;·&nbsp; EST. 2007</div>
        <h1 class="m-0 font-display font-extrabold text-ink" style="font-size:clamp(40px,5.6vw,72px);line-height:1.05;letter-spacing:-1px;">
          <span data-anim class="block" style="--d:.28s">Pressure Cookers</span>
          <span data-anim class="block" style="--d:.42s">Built on <span class="text-accent-text italic">17 Years</span></span>
          <span data-anim class="block" style="--d:.56s">of Craft.</span>
        </h1>
        <p data-anim class="text-body leading-[1.7] max-w-[48ch] mt-7" style="--d:.7s;font-size:clamp(16px,1.4vw,18.5px);">
          H.P. Industries manufactures premium aluminium pressure cookers from Uttar Pradesh, India — engineered for everyday kitchens and trusted by wholesale partners nationwide.
        </p>
        <div data-anim class="flex flex-wrap gap-4 mt-[38px]" style="--d:.84s">
          <a href="#products" class="hp-btn-primary text-base px-[30px] py-4">Explore Products <span style="font-family:var(--font-mono)">&rarr;</span></a>
          <a href="/contact.html" class="hp-btn-outline text-base px-[30px] py-4">Contact Us</a>
        </div>
        <div data-anim class="flex flex-wrap gap-x-[22px] gap-y-[10px] mt-[34px] font-mono text-[11.5px] tracking-[1px] text-muted" style="--d:.98s">
          <span>ISO-GRADE SAFETY</span><span class="text-accent-text">/</span>
          <span>BULK ORDERS</span><span class="text-accent-text">/</span>
          <span>PAN-INDIA SHIPPING</span>
        </div>
      </div>
      <div data-anim class="relative flex justify-center items-center" style="--d:.5s">
        <div class="absolute rounded-full" style="width:108%;aspect-ratio:1;background:radial-gradient(circle,#FFFFFF 0%,var(--hp-imgbg) 55%,transparent 72%);"></div>
        <div class="absolute rounded-full" style="width:78%;aspect-ratio:1;border:1px dashed color-mix(in srgb,var(--hp-copper) 35%,transparent);animation:var(--animate-spin-slow);"></div>
        <div class="relative w-full max-w-[440px]" style="animation:var(--animate-float);">
          <img src="/images/products/contura.png" alt="HP Contura aluminium pressure cooker" class="w-full block rounded-[18px]" style="filter:drop-shadow(0 30px 50px rgba(120,80,40,.22));" />
        </div>
        <div class="absolute flex items-center gap-[11px] bg-surface rounded-[14px] px-[17px] py-[13px]" style="bottom:6%;left:2%;border:1px solid var(--hp-border);box-shadow:0 18px 36px -18px rgba(31,36,51,.3);">
          <span class="w-[38px] h-[38px] rounded-[10px] flex items-center justify-center" style="background:#EAF3EC;"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#2D7A4F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span>
          <span class="leading-[1.2]"><span class="block font-mono text-[11px]" style="color:#2D7A4F;">ISI-STANDARD</span><span class="block text-[12.5px] text-body mt-[2px]">Tested &amp; safe</span></span>
        </div>
      </div>
    </div>
  </header>

  <!-- TRUST / STATS -->
  <section style="background:var(--hp-warm);border-top:1px solid var(--hp-border);border-bottom:1px solid var(--hp-border);">
    <div class="mx-auto grid gap-[30px] max-[640px]:grid-cols-2" style="max-width:1180px;padding:48px clamp(20px,5vw,64px);grid-template-columns:repeat(4,1fr);">
      {site.stats.map((s, i) => (
        <div data-reveal data-delay={i * 80}>
          <div class="font-display font-bold text-ink leading-none" style="font-size:clamp(34px,4vw,50px);"><span data-count={s.value} data-suffix={s.suffix}>0</span></div>
          <div class="font-mono text-xs tracking-[2px] text-accent-text mt-[10px]">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- PRODUCT HIGHLIGHTS -->
  <section id="products" class="bg-bg" style="padding:clamp(70px,9vw,118px) clamp(20px,5vw,64px);">
    <div class="mx-auto" style="max-width:1180px;">
      <div data-reveal class="text-center max-w-[640px] mx-auto mb-14">
        <div class="hp-eyebrow mb-4">OUR RANGE</div>
        <h2 class="hp-h2">Three cooker styles, eight sizes</h2>
        <p class="text-muted text-[17px] leading-[1.6] mt-[18px]">Each cooker is forged from premium aluminium and finished with HP's signature locking and safety system.</p>
      </div>
      <div class="grid gap-[26px] max-[860px]:grid-cols-1" style="grid-template-columns:repeat(3,1fr);">
        {featured.map((p) => <ProductCard product={p} variant="highlight" />)}
      </div>
    </div>
  </section>

  <!-- ANATOMY SHOWCASE -->
  <section id="anatomy" class="hp-anatomy relative overflow-hidden" style="background:linear-gradient(165deg,var(--hp-bg) 0%,var(--hp-warm) 100%);padding:clamp(64px,8vw,104px) clamp(20px,5vw,64px);">
    <div class="absolute pointer-events-none" style="top:50%;left:50%;transform:translate(-50%,-50%);width:60vw;height:60vw;max-width:720px;max-height:720px;background:radial-gradient(circle,color-mix(in srgb,var(--hp-copper) 10%,transparent),transparent 65%);"></div>
    <div class="relative text-center max-w-[640px] mx-auto mb-[18px]">
      <div data-reveal>
        <div class="hp-eyebrow mb-[14px]">ENGINEERED WITH PURPOSE</div>
        <h2 class="hp-h2">Every Part. Built to Last.</h2>
        <p class="text-muted text-base leading-[1.6] mt-4">Six engineered components, each branded and tested — annotated here on the HP Contura.</p>
      </div>
    </div>
    <div class="relative mx-auto mt-[18px] grid items-center max-[820px]:grid-cols-1 max-[820px]:justify-items-center" style="max-width:1080px;grid-template-columns:1fr minmax(260px,400px) 1fr;gap:clamp(12px,3vw,40px);">
      <div class="flex flex-col items-end max-[820px]:items-center" style="gap:clamp(26px,5vh,52px);">
        {leftCallouts.map((cl, i) => (
          <div data-callout class="flex items-center gap-[13px] w-full justify-end" style={`--seq:${leftSeq[i]};--fx:-14px;`}>
            <div class="text-right"><span class="block font-mono text-[13.5px] text-accent-text">{cl.name}</span><span class="block text-xs text-muted mt-[3px]">{cl.sub}</span></div>
            <div data-line class="relative flex-none" style="width:clamp(28px,4vw,54px);height:1.5px;background:var(--hp-copper);transform-origin:right;"><span class="absolute rounded-full" style="right:-3px;top:-2.5px;width:6px;height:6px;background:var(--hp-copper);"></span></div>
          </div>
        ))}
      </div>
      <div class="relative flex justify-center items-center">
        <div data-anatomy-ring class="absolute rounded-full" style="width:104%;aspect-ratio:1;border:1.5px solid color-mix(in srgb,var(--hp-copper) 50%,transparent);box-shadow:0 0 50px -6px color-mix(in srgb,var(--hp-copper) 40%,transparent);"></div>
        <div class="absolute rounded-full" style="width:96%;aspect-ratio:1;background:radial-gradient(circle,#fff 0%,var(--hp-imgbg) 60%,transparent 74%);"></div>
        <div data-steam class="absolute z-[3]" style="top:6%;left:50%;transform:translateX(-50%);width:26px;height:46px;">
          <span class="absolute rounded-full" style="left:2px;bottom:0;width:7px;height:7px;background:rgba(120,80,40,.35);animation:hpSteam 2.6s ease-in-out infinite;"></span>
          <span class="absolute rounded-full" style="left:13px;bottom:0;width:6px;height:6px;background:rgba(120,80,40,.28);animation:hpSteam 2.6s ease-in-out .7s infinite;"></span>
        </div>
        <div class="relative w-full max-w-[380px] z-[2]" style="animation:var(--animate-float);">
          <img src="/images/products/contura.png" alt="HP Contura pressure cooker — annotated" class="w-full block rounded-[16px]" style="filter:drop-shadow(0 26px 44px rgba(120,80,40,.24));" />
        </div>
      </div>
      <div class="flex flex-col items-start max-[820px]:items-center" style="gap:clamp(26px,5vh,52px);">
        {rightCallouts.map((cl, i) => (
          <div data-callout class="flex items-center gap-[13px] w-full" style={`--seq:${rightSeq[i]};--fx:14px;`}>
            <div data-line class="relative flex-none" style="width:clamp(28px,4vw,54px);height:1.5px;background:var(--hp-copper);transform-origin:left;"><span class="absolute rounded-full" style="left:-3px;top:-2.5px;width:6px;height:6px;background:var(--hp-copper);"></span></div>
            <div><span class="block font-mono text-[13.5px] text-accent-text">{cl.name}</span><span class="block text-xs text-muted mt-[3px]">{cl.sub}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY HP -->
  <section id="about" style="background:var(--hp-warm);padding:clamp(70px,9vw,118px) clamp(20px,5vw,64px);">
    <div class="mx-auto" style="max-width:1180px;">
      <div data-reveal class="max-w-[640px] mb-[54px]">
        <div class="hp-eyebrow mb-4">WHY H.P. INDUSTRIES</div>
        <h2 class="hp-h2">A manufacturing partner you can build on</h2>
      </div>
      <div class="grid gap-px rounded-[18px] overflow-hidden max-[860px]:grid-cols-1 min-[861px]:grid-cols-3" style="background:var(--hp-border);border:1px solid var(--hp-border);">
        {data.why.map((w, i) => (
          <div data-reveal data-delay={(i % 3) * 80} class="bg-surface" style="padding:34px 30px;">
            <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="var(--hp-accenttext)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={w.icon}></svg>
            <h3 class="font-display font-bold text-ink text-[21px] mt-[18px] mb-2" set:html={w.title}></h3>
            <p class="m-0 text-muted text-[14.5px] leading-[1.6]">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SAFETY BAND -->
  <section id="safety" class="bg-bg" style="padding:clamp(70px,9vw,118px) clamp(20px,5vw,64px);">
    <div class="mx-auto" style="max-width:1180px;">
      <div data-reveal class="text-center max-w-[620px] mx-auto mb-[50px]">
        <div class="hp-eyebrow mb-4" style="color:var(--color-success);">SAFETY FIRST</div>
        <h2 class="hp-h2">Your safety is our standard</h2>
        <p class="text-muted text-[17px] leading-[1.6] mt-[18px]">Four engineered safeguards work together on every HP cooker — tested at industry-standard PSI ratings.</p>
      </div>
      <div class="grid gap-5 max-[640px]:grid-cols-1 max-[980px]:grid-cols-2 min-[981px]:grid-cols-4">
        {data.safety.map((s, i) => (
          <div data-safety data-reveal data-delay={i * 80} class="rounded-2xl px-6 py-7" style="background:var(--hp-safe);border:1px solid var(--hp-safeborder);">
            <div data-badge class="w-[46px] h-[46px] rounded-xl flex items-center justify-center mb-[18px]" style="background:var(--color-success);"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" set:html={SAFETY_ICONS[i % SAFETY_ICONS.length]}></svg></div>
            <div class="font-mono text-sm text-ink mb-2">{s.name}</div>
            <p class="m-0 text-muted text-[13.5px] leading-[1.6]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT TEASER -->
  <section class="relative overflow-hidden" style="background:var(--hp-warm);padding:clamp(70px,9vw,118px) clamp(20px,5vw,64px);">
    <div class="relative mx-auto grid items-center max-[820px]:grid-cols-1" style="max-width:1180px;grid-template-columns:1fr 1fr;gap:64px;">
      <div data-reveal class="pl-[30px]" style="border-left:3px solid var(--hp-copper);">
        <p class="font-display italic font-medium text-ink m-0 mb-[26px]" style="font-size:clamp(22px,2.6vw,31px);line-height:1.4;">We don't just assemble cookers — we build trust into every weld, seal and valve.</p>
        <div class="flex items-center gap-[14px]">
          <div class="w-[46px] h-[46px] rounded-full flex items-center justify-center font-display text-white font-bold" style="background:var(--hp-copper);">{site.contact.owner.initials}</div>
          <div><div class="text-ink font-semibold text-[15px]">{site.contact.owner.name}</div><div class="text-muted text-[13px] font-mono mt-[3px]">{site.contact.owner.role}</div></div>
        </div>
      </div>
      <div data-reveal data-delay="120">
        <div class="hp-eyebrow mb-[18px]">OUR STORY</div>
        <h2 class="m-0 mb-[18px] font-display font-bold text-ink" style="font-size:clamp(26px,3vw,38px);line-height:1.15;">From a small UP workshop to a trusted manufacturer</h2>
        <p class="text-body text-base leading-[1.7] m-0 mb-[26px]">Founded in 2007, H.P. Industries has spent nearly two decades perfecting the aluminium pressure cooker — combining hands-on craft with steady investment in tooling, testing and people. Today we serve retail customers and wholesale partners across India.</p>
        <a href="/contact.html" class="hp-btn-outline text-[15px] px-[26px] py-[13px]">Learn More <span style="font-family:var(--font-mono)">&rarr;</span></a>
      </div>
    </div>
  </section>

  <!-- GALLERY STRIP -->
  <section id="gallery" class="bg-bg" style="padding:clamp(70px,9vw,118px) 0;">
    <div class="mx-auto" style="max-width:1180px;padding:0 clamp(20px,5vw,64px);">
      <div data-reveal class="flex justify-between items-end flex-wrap gap-4 mb-10">
        <div>
          <div class="hp-eyebrow mb-4">GALLERY</div>
          <h2 class="hp-h2">Our work in detail</h2>
        </div>
        <span class="font-mono text-xs text-muted">DRAG / SCROLL &rarr;</span>
      </div>
    </div>
    <div class="flex gap-[18px] overflow-x-auto" style="padding:6px clamp(20px,5vw,64px) 26px;scroll-snap-type:x mandatory;">
      {site.gallery.map((g) => (
        <div class="hp-gal relative flex-none w-[340px] h-[260px] rounded-2xl overflow-hidden bg-imgbg" style="scroll-snap-align:start;">
          <img src={g.img} alt={g.caption} class="w-full h-full object-cover block" />
          <div class="hp-gal-ov absolute inset-0 flex items-end p-[18px]" style="background:linear-gradient(0deg,color-mix(in srgb,var(--hp-copper) 82%,transparent),transparent 60%);">
            <span class="font-mono text-xs text-white">{g.caption}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA BANNER -->
  <section id="quote" class="relative overflow-hidden" style="background:var(--hp-copper);">
    <div class="absolute inset-0" style="background:radial-gradient(60% 120% at 80% 0%,rgba(255,255,255,.16),transparent 60%);"></div>
    <div data-reveal class="relative mx-auto flex flex-wrap gap-[30px] items-center justify-between" style="max-width:1180px;padding:clamp(56px,7vw,90px) clamp(20px,5vw,64px);">
      <div>
        <h2 class="m-0 font-display font-bold text-onaccent max-w-[18ch]" style="font-size:clamp(28px,3.6vw,44px);line-height:1.1;">Ready to place a bulk order?</h2>
        <p class="text-onaccent opacity-85 text-base mt-[14px]">Tell us your sizes and volumes — we'll send a quote and dispatch timeline.</p>
      </div>
      <a href="/contact.html" class="inline-flex items-center gap-[10px] text-white no-underline font-semibold text-base px-[34px] py-[17px] rounded-full" style="background:#1A2340;box-shadow:0 14px 30px -12px rgba(0,0,0,.5);">Get a Quote <span style="font-family:var(--font-mono)">&rarr;</span></a>
    </div>
  </section>
</Base>
